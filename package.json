{
  "name": "@stfade/pi-read-delegator",
  "version": "1.0.13",
  "description": "Pi extension that delegates all read operations to a Reader subagent, blocking read tools from the main model",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "pi-extension": true,
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/config.js",
    "dist/config.d.ts",
    "dist/tool-blocker.js",
    "dist/tool-blocker.d.ts",
    "dist/bash-filter.js",
    "dist/bash-filter.d.ts",
    "dist/reader-manager.js",
    "dist/reader-manager.d.ts",
    "dist/ui.js",
    "dist/ui.d.ts",
    "dist/templates/reader.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "read-delegator",
    "subagent",
    "reader"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "pi-subagents": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  }
}
